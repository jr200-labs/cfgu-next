{
  "name": "@configu/cli",
  "description": "Configu CLI",
  "version": "0.0.0",
  "author": {
    "name": "@configu/dev",
    "email": "dev@configu.com",
    "url": "https://configu.com"
  },
  "bin": {
    "configu": "./dist/configu.cjs"
  },
  "bugs": "https://github.com/configu/configu/issues",
  "dependencies": {
    "@clack/prompts": "^1.7.0",
    "@configu/common": "workspace:*",
    "@configu/formatters": "workspace:*",
    "@configu/sdk": "workspace:*",
    "@pnpm/os.env.path-extender": "^3.0.1",
    "adm-zip": "^0.6.0",
    "clipanion": "^4.0.0-rc.4",
    "get-stdin": "^9.0.0",
    "open": "^11.0.0",
    "open-editor": "^6.0.0",
    "openid-client": "^5.7.1",
    "tar": "^7.5.21",
    "typanion": "^3.14.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8"
  },
  "exports": {
    "./package.json": "./package.json"
  },
  "files": [
    "/dist"
  ],
  "homepage": "https://configu.com",
  "keywords": [
    "cfgu",
    "configu",
    "configu-cli",
    "configu-command-line"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/configu/configu",
    "directory": "packages/cli"
  },
  "scripts": {
    "build": "tsx compile.mts",
    "build:binary": "tsx build.mts",
    "build:docker": "docker buildx build --progress plain --load -t configu/cli -f ./Dockerfile ../..",
    "clean": "shx rm -rf dist",
    "dev": "DEBUG=configu tsx src/configu.ts",
    "prebuild": "pnpm run clean",
    "prestart": "pnpm build",
    "start": "node dist/configu.cjs"
  },
  "type": "module"
}
